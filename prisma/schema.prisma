// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
} 


//contents
model Contents {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  termsAndCondition String
  privacyPolicy     String 
  refundPolicy      String
  shippingPolicy    String
  aboutUs           String
  location          String
  copyRight         String
  footerText        String  

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

 @@map("contents")
} 


model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  email       String   @unique
  password    String?
  status      status   @default(active)
  role        Role     @default(user)
  profile     String?
  phoneNumber String?
  customerId String?
  location   Json?
  expireAt    DateTime? @default(now())
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  verification     Verification? 
  serviceProviderInfo     serviceProviderInfo? 
  workSchedule     workSchedule[] 
  deviceHistory    DeviceHistory[]  
  notifications    Notification[]  
  // reviews    Reviews[]  
  reviewsReceived Reviews[] @relation("UserReviews")
  reviewsGiven    Reviews[] @relation("AuthorReviews")
}

model DeviceHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  ip        String?
  browser   String?
  os        String?
  device    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Verification { 
  userId    String   @map("_id") @db.ObjectId
  otp       Int
  expiredAt DateTime?
  status    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@id([userId])
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  receiverId String? @db.ObjectId
  referenceId String? @db.ObjectId 
  message String
  description String?
  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   user    User?     @relation(fields: [receiverId], references: [id]) 
}

model workSchedule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  day  Days  
  startTime DateTime
  endTime DateTime
  status Boolean @default(true)  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  user User @relation(fields: [userId], references: [id])

 
}


model serviceProviderInfo {
  userId    String   @map("_id") @db.ObjectId
  palliativeCare Boolean @default(false)
  drivingLicense Boolean @default(false)
  businessProfiles Boolean @default(false)
  documents String 
  perHourPrice Float
  experience  YearsSkating @default(ZERO_TO_TWO)
  qualifiedCarer Boolean @default(false) 



  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  user User @relation(fields: [userId], references: [id])

  @@id([userId])
}


model Categories{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
  image String 
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Reviews {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  rating Float 
  review String
  userId String @db.ObjectId
  authorId String @db.ObjectId

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  user   User @relation("UserReviews", fields: [userId], references: [id])
  author User @relation("AuthorReviews", fields: [authorId], references: [id])
 
  
}


model Bookings {
  id String @id @map("_id") @default(auto()) @db.ObjectId
  userId String @db.ObjectId
  serviceProviderId String @db.ObjectId 
  
}

// Enums 
enum status {
  active
  blocked
}

enum YearsSkating {
  ZERO_TO_TWO          @map("0-2")
  THREE_TO_FIVE        @map("3-5")
  SIX_TO_TEN           @map("6-10")
  ELEVEN_TO_TWENTY     @map("11-20")
  TWENTY_PLUS          @map("20+")
}
enum Days {
  Mon
  Tue
  Wed  
  Thu   
  Fri   
  Sat   
  Sun  
}
 
enum Role {
  admin
  sub_admin
  supper_admin
  user
  service_provider
}